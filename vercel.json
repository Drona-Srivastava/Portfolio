{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "/(js|css|img)/(.+)",
      "dest": "/dist/$1/$2"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^/(?!assets/).*",
      "dest": "/index.html"
    }
  ]
}
